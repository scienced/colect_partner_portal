# Database
DATABASE_URL="postgresql://user:password@localhost:5432/colect_partner_portal"

# SuperTokens
SUPERTOKENS_CONNECTION_URI="https://your-supertokens-cloud.supertokens.io"
SUPERTOKENS_API_KEY="your-api-key"
NEXT_PUBLIC_SUPERTOKENS_APP_NAME="Colect Partner Portal"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AWS S3
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="colect-partner-portal-assets"

# Email (Postmark)
POSTMARK_API_KEY="your-postmark-key"
EMAIL_FROM="portal@colect.com"

# Cron Secret (for weekly digest)
CRON_SECRET="your-cron-secret"

# Screenshot API (for thumbnail generation)
SCREENSHOTBASE_KEY="your-screenshotbase-key"
