# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Database (Neon recommended: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# SuperTokens Authentication (https://supertokens.com)
SUPERTOKENS_CONNECTION_URI="https://your-app.supertokens.io"
SUPERTOKENS_API_KEY="your-api-key"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AWS S3 Storage
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="your-bucket-name"

# ===========================================
# BRANDING (Optional - customize your portal)
# ===========================================

# Company name and portal title
# NEXT_PUBLIC_SITE_NAME="Your Company"
# NEXT_PUBLIC_SITE_TITLE="Partner Portal"
# NEXT_PUBLIC_SITE_TAGLINE="Partner-only workspace for resellers"
# NEXT_PUBLIC_SUPPORT_EMAIL="support@yourcompany.com"

# Primary brand color (hex format)
# NEXT_PUBLIC_PRIMARY_COLOR="#ef556d"

# Logo (external URL recommended, or path in /public folder)
# NEXT_PUBLIC_LOGO_URL="https://your-bucket.s3.amazonaws.com/logo.png"
# NEXT_PUBLIC_LOGO_WIDTH="120"
# NEXT_PUBLIC_LOGO_HEIGHT="40"

# Documentation site URL (shown in admin placeholders)
# NEXT_PUBLIC_DOCS_URL="https://docs.yourcompany.com"

# ===========================================
# OPTIONAL FEATURES
# ===========================================

# Email (Postmark) - for digest emails (not fully implemented)
# POSTMARK_API_KEY="your-postmark-key"
# EMAIL_FROM="portal@yourcompany.com"

# Cron Secret - for scheduled tasks
# CRON_SECRET="your-random-secret"

# Screenshot API - for auto-generating campaign thumbnails from HTML files
# Only needed if you want automatic thumbnail generation for campaigns
# Get your API key at: https://screenshotbase.com
# SCREENSHOTBASE_KEY="your-screenshotbase-key"

# GitBook integration - auto-populates the Docs Updates feed with recently
# updated pages from your GitBook documentation. Both vars must be set for
# the feature to activate; otherwise only manual Docs Updates appear.
# Get an API token: GitBook → Account Settings → Developer → Personal Access Tokens
# GITBOOK_API_TOKEN="gb_api_xxx"
# GITBOOK_ORG_ID="your-gitbook-org-id"

# GitBook custom-auth signing key - used to sign JWTs for Colect's
# auth-gated admin docs. Unrelated to the auto-feed feature.
# GITBOOK_PRIVATE_KEY="uuid-signing-key"
